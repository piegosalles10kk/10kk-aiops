NODE_ENV=development
PORT=3333
LOG_LEVEL=info

DATABASE_URL=postgresql://aiops:aiops_password@localhost:5432/aiops?schema=public

GLPI_API_URL=http://localhost:8080/api.php/v1
GLPI_WEB_URL=http://localhost:8080
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GRAFANA_URL=https://metrics.omni-inbox.ai
GRAFANA_SA_TOKEN=
LOKI_SCAN_ENABLED=true
LOKI_SCAN_ENVIRONMENTS=prod,homolog
LOKI_SCAN_INTERVAL_MS=300000
LOKI_SCAN_MIN_COUNT=3

# Scanner unificado dos datasources do Grafana
OBSERVABILITY_SCAN_ENABLED=true
OBSERVABILITY_SCAN_INTERVAL_MS=300000
OBSERVABILITY_MAX_PER_CYCLE=5
PROMETHEUS_CPU_THRESHOLD=90
PROMETHEUS_MEMORY_THRESHOLD=90
PROMETHEUS_DISK_THRESHOLD=90
PROMETHEUS_SERVICE_CPU_THRESHOLD=85
PROMETHEUS_5XX_RATE_THRESHOLD=0.1
PROMETHEUS_LATENCY_THRESHOLD_SECONDS=2
PROMETHEUS_AUTH_FAILURE_THRESHOLD=20
WAZUH_MIN_LEVEL=12
WAZUH_SCAN_LOOKBACK_MIN=10

TRELLO_API_KEY=
TRELLO_TOKEN=
# Lista de incidentes (cards aqui viram chamados tipo Incidente no GLPI)
TRELLO_LIST_ID_INCIDENT=
# Lista de requisicoes (cards aqui viram chamados tipo Requisicao no GLPI)
TRELLO_LIST_ID_REQUEST=
TRELLO_LIST_ID_IN_PROGRESS=
TRELLO_LIST_ID_DONE=

# Intervalo do loop de sincronizacao GLPI <-> Trello (ms)
SYNC_INTERVAL_MS=30000

SLACK_WEBHOOK_URL=

# Central de comando
CONFIG_ENCRYPTION_KEY=troque-por-uma-chave-longa-e-aleatoria
RUNNER_URL=http://host.docker.internal:3340
RUNNER_TOKEN=troque-este-token
QDRANT_URL=http://qdrant:6333
AGENT_POLL_INTERVAL_MS=15000
PROJECTS_HOST_ROOT=C:\caminho\para\seus\projetos

# Telegram e Gerente
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
MANAGER_MODEL=gemini-2.5-flash
GLPI_AGENT_PROFILE_ID=
GLOBAL_AGENT_PROMPT=
